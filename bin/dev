#!/usr/bin/env sh

# Example Usage:
# bin/dev
# ./bin/dev
# ./bin/dev -p 8000
# ./bin/dev --port 8000
# PORT=8000 ./bin/dev

if gem list --no-installed --exact --silent foreman; then
  echo "Installing foreman..."
  gem install foreman
fi

# Default to port 3000 if not specified
export PORT="${PORT:-3000}"

exec foreman start -f Procfile.dev --env /dev/null "$@"
