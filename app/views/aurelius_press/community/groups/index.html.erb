<div class="container">
  <h1>Groups</h1>

  <% @groups.each do |group| %>
    <div id="<%= dom_id(group) %>">
      <h2><%= link_to group.name, aurelius_press_community_group_path(group) %></h2>
      <p><%= group.description %></p>
      <p><%= group.members.count %> members</p>
    </div>
  <% end %>
</div>
