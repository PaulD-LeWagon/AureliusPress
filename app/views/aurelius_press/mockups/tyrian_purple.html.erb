<div class="theme-wrapper tyrian-luxury">
  <nav class="glass-navbar desktop-nav">
    <div class="nav-container">
      <div class="logo">Aurelius<span>Press</span></div>
      <ul class="nav-links">
        <li><a href="#" class="active">Discover</a></li>
        <li><a href="#">Writers</a></li>
        <li><a href="#">The Archive</a></li>
        <li><a href="#" class="btn-primary">Subscribe</a></li>
      </ul>
      <div class="mobile-menu-toggle">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
  </nav>

  <section id="brand-hero" class="hero-section">
    <div class="hero-content">
      <h1 class="fade-in">The Art of <span>Deep Thought</span></h1>
      <p class="fade-in-delay">Curated wisdom for the modern polymath. Experience journalism with the richness of Tyrian Purple.</p>
      <div class="cta-group fade-in-delay">
        <a href="#" class="btn-primary">Start Reading</a>
        <a href="#" class="btn-secondary">Learn More</a>
      </div>
    </div>
    <div class="hero-overlay"></div>
  </section>

  <main class="content-container">
    <header class="section-header">
      <h2>Latest from the Archive</h2>
      <div class="accent-line"></div>
    </header>

    <div class="content-grid">
      <% 3.times do |i| %>
        <article class="article-card">
          <div class="card-image-placeholder"></div>
          <div class="card-body">
            <span class="category">PHILOSOPHY</span>
            <h3>The Stoic Resilience in a Digital Age [Sample <%= i + 1 %>]</h3>
            <p>Exploring how ancient wisdom can provide a buffer against the chaotic streams of modern social media.</p>
            <div class="card-footer">
              <span class="author">Marcus Aurelius II</span>
              <a href="#" class="read-more">Read Entry →</a>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  </main>

  <footer class="modern-footer">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="logo">Aurelius<span>Press</span></div>
        <p>A sanctuary for intellectual exploration and timeless discourse.</p>
      </div>
      <div class="footer-links">
        <h4>Navigation</h4>
        <ul>
          <li><a href="#">Ethos</a></li>
          <li><a href="#">Collection</a></li>
          <li><a href="#">Community</a></li>
        </ul>
      </div>
      <div class="footer-links">
        <h4>Legal</h4>
        <ul>
          <li><a href="#">Terms</a></li>
          <li><a href="#">Privacy</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      &copy; 2026 AureliusPress. All Rights Reserved.
    </div>
  </footer>
</div>
