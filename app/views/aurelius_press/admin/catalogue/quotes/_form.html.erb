<% if controller_path.include?("admin") %>
  <% in_admin_ns = true %>
  <% form_url = (@quote.new_record? ? aurelius_press_admin_catalogue_quotes_path : aurelius_press_admin_catalogue_quote_path(@quote)) %>
<% else %>
  <% in_admin_ns = false %>
  <% form_url = (@quote.new_record? ? aurelius_press_catalogue_quotes_path : aurelius_press_catalogue_quote_path(@quote)) %>
<% end %>

<%= simple_form_for @quote, url: form_url, html: { class: "pico-page-form" }, data: { controller: "auto-slugify" } do |form| %>

  <%= form.error_notification %>

  <%
    # == Schema Information
    #
    # Table name: aurelius_press_quotes
    #
    #  id                :bigint           not null, primary key
    #  text              :text
    #  context           :string
    #  source_id         :bigint           not null
    #  original_quote_id :bigint
    #  slug              :string
    #  created_at        :datetime         not null
    #  updated_at        :datetime         not null
    #  comments_enabled  :boolean          default(FALSE), not null
    #
  %>

  <div class="form-inputs">
    <div class="row">
      <div class="column">
        <%= form.input :text, as: :text, required: true, autofocus: true, input_html: { rows: 5 } %>
      </div>
    </div>
    <div class="row">
      <div class="column">
        <%= form.input :context %>
      </div>
    </div>
    <div class="row">
      <div class="column">
        <%= form.input :source_id, as: :select, collection: @sources, label_method: :title, value_method: :id, required: true %>
      </div>
    </div>
    <div class="row">
      <div class="column">
        <%= form.input :original_quote_id, as: :select, collection: @original_quotes, label_method: :text, value_method: :id, prompt: "Is this a variant?", hint: "Use this field to link this quote as a variant to another." %>
      </div>
    </div>
    <div class="row">
      <div class="column">
        <%= form.input :comments_enabled, as: :boolean, input_html: { role: "switch" } %>
      </div>
    </div>

    <div class="grid row" style="grid-template-columns: 1fr 1fr; margin-top: 1rem;">
      <div class="column">
        <%= render "aurelius_press/admin/taxonomy/search_select", 
                   id: "category-search-input",
                   label: "Categories",
                   attribute_name: "quote[category_ids][]",
                   url: aurelius_press_api_v1_taxonomy_categories_path,
                   create_url: "#", 
                   selected_items: @quote.categories %>
      </div>

      <div class="column">
        <%= render "aurelius_press/admin/taxonomy/search_select", 
                   id: "tag-search-input",
                   label: "Tags",
                   attribute_name: "quote[tag_ids][]",
                   url: aurelius_press_api_v1_taxonomy_tags_path,
                   create_url: aurelius_press_api_v1_taxonomy_tags_path,
                   selected_items: @quote.tags %>
      </div>
    </div>
  </div>

  <div class="form-actions grid">

    <% if in_admin_ns %>

      <% if @quote.persisted? %>

        <%= link_to "Delete", aurelius_press_admin_catalogue_quote_path(@quote), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "button danger", role: "button" %>

      <% end %>

      <%= link_to "Back", aurelius_press_admin_catalogue_quotes_path, class: "button warning", role: "button" %>

    <% else %>

      <% if @quote.persisted? %>

        <%= link_to "Delete", aurelius_press_catalogue_quote_path(@quote), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "button danger", role: "button" %>

      <% end %>

      <%= link_to "Back", aurelius_press_catalogue_quotes_path, class: "button warning", role: "button" %>

    <% end %>

    <%= form.button :submit, value: @quote.new_record? ? "Create" : "Update", class: "button success", role: "button" %>

  </div>
<% end %>
