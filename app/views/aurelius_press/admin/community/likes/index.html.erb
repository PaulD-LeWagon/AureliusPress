<h1>Likes</h1>
<%= link_to 'New Like', new_aurelius_press_admin_community_like_path %>
<table>
  <thead>
    <tr>
      <th>User</th>
      <th>Likeable</th>
      <th>State</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @likes.each do |like| %>
      <tr>
        <td><%= like.user.id %></td>
        <td><%= like.likeable_type %> #<%= like.likeable_id %></td>
        <td><%= like.state %></td>
        <td>
            <%= link_to 'Show', aurelius_press_admin_community_like_path(like) %>
            <%= link_to 'Edit', edit_aurelius_press_admin_community_like_path(like) %>
            <%= link_to 'Destroy', aurelius_press_admin_community_like_path(like), method: :delete, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
