<%= render HeroComponent.new(
     title: "AureliusPress::Admin::Taxonomy::Tags#show",
     subtitle: "Find me in app/views/aurelius_press/admin/taxonomy/tags/show.html.erb",
     small: true,
   ) %>

<div class="container" template="AureliusPress::Admin::Taxonomy::Tags#show">

  <%= link_to 'Edit Tag', edit_aurelius_press_admin_taxonomy_tag_path(@tag), class: 'button warning', role: 'button' %>
  <%= link_to 'Back to Tags', aurelius_press_admin_taxonomy_tags_path, class: 'button secondary', role: 'button' %>
  <%= link_to 'Delete Tag', aurelius_press_admin_taxonomy_tag_path(@tag), data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' }, class: 'button danger', role: 'button' %>

  <hr>

  <div class="row">

    <h3><%= @tag.name %></h3>
    <hr>
    <p><strong>Name:</strong> <%= @tag.name %></p>
    <p><strong>Slug:</strong> <%= @tag.slug %></p>
    <p><strong>Created At:</strong> <%= l(@tag.created_at, format: :long) %></p>
    <p><strong>Updated At:</strong> <%= l(@tag.updated_at, format: :long) %></p>

    <h2>Posts in this tag</h2>
    <% if @tag.blog_posts.any? %>
      <ul>
        <% @tag.blog_posts.each do |post| %>
          <li>
            <%= link_to post.title, aurelius_press_admin_document_blog_post_path(post) %> - <em><%= l(post.created_at, format: :short) %></em>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>No posts found in this tag. <%= link_to 'Create one?', new_aurelius_press_admin_document_blog_post_path %></p>
    <% end %>

    <h2>Atomic Posts in this tag</h2>
    <% if @tag.atomic_blog_posts.any? %>
      <ul>
        <% @tag.atomic_blog_posts.each do |post| %>
          <li>
            <%= link_to post.title, aurelius_press_admin_document_atomic_blog_post_path(post) %> - <em><%= l(post.created_at, format: :short) %></em>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>No posts found in this tag. <%= link_to 'Create one?', new_aurelius_press_admin_document_blog_post_path %></p>
    <% end %>

    <h2>Pages in this tag</h2>
    <% if @tag.pages.any? %>
      <ul>
        <% @tag.pages.each do |page| %>
          <li>
            <%= link_to page.title, aurelius_press_admin_document_page_path(page) %> - <em><%= l(page.created_at, format: :short) %></em>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>No pages found in this tag. <%= link_to 'Create one?', new_aurelius_press_admin_document_page_path %></p>
    <% end %>

  </div>
</div>
