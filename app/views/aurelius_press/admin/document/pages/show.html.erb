<div class="hero-banner small flex justify-center items-center">
  <hgroup class="container">
    <h1>AureliusPress::Admin::Document::Pages#show</h1>
    <p>View an existing page in the AureliusPress application.</p>
  </hgroup>
</div>

<div class="container">

  <div class="page-links">
    <%= link_to "Edit", edit_aurelius_press_admin_document_page_path(@page) %> |
    <%= link_to "Delete", aurelius_press_admin_document_page_path(@page), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %> |
    <%= link_to "Back to Pages", aurelius_press_admin_document_pages_path %>
  </div>


  <h2><%= @page.title %></h2>
  <% if @page.subtitle.present? %>
    <h3><%= @page.subtitle %></h3>
  <% end %>

  <p>
    <strong>Author:</strong>
    <%= @page.user.full_name %>
  </p>

  <p>
    <strong>Description:</strong>
    <%= @page.description %>
  </p>

  <p>
    <strong>Status:</strong>
    <%= @page.status.humanize %>
  </p>

  <p>
    <strong>Visibility:</strong>
    <%= @page.visibility.humanize %>
  </p>

  <p>
    <strong>Published At:</strong>
    <%= @page.published_at %>
  </p>

  <div style="margin: 1rem 0;">
    <%= render "aurelius_press/taxonomy/shared/labels", interactable: @page %>
  </div>

  <p>
    <strong>Comments Enabled:</strong>
    <%= @page.comments_enabled ? "Yes" : "No" %>
  </p>

  <div class="content-blocks">
    <h3>Content Blocks</h3>
    <% @page.content_blocks.order(:position).each do |content_block| %>
      <%= render content_block %>
    <% end %>
  </div>

  <% if @page.comments_enabled %>
    <div class="comment-section">
      <h3>Comments</h3>
      <% @page.comments.each do |comment| %>
        <div class="comment">
          <p><strong><%= comment.user&.full_name || 'Unknown User' %>:</strong> <%= comment.content.body %></p>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @page.notes.any? %>
    <div class="note-section">
      <h3>Notes</h3>
      <% @page.notes.each do |note| %>
        <div class="note">
          <p><strong><%= note.user&.full_name || 'Unknown User' %>:</strong> <%= note.content.body %></p>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
