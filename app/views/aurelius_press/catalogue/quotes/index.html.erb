<%= render HeroComponent.new(
  title: "AureliusPress::Catalogue::Quotes#index",
  subtitle: "Find me in app/views/aurelius_press/catalogue/quotes/index.html.erb",
  small: true
) %>

<div class="container" template="AureliusPress::Catalogue::Quotes#index">
  <div class="section">
    <h2 class="title is-4">All Quotes</h2>
    <p>Welcome to the quotes index page. Here you can find a collection of insightful quotes from various authors and sources.</p>
    <ul>
      <% @quotes.each do |quote| %>
        <li>
          <%= link_to quote.text.truncate(50), aurelius_press_catalogue_quote_path(quote) %>
          from
          <%= link_to quote.source.title, aurelius_press_catalogue_source_path(quote.source) %>
          by
          <% quote.source_authors.each do |author| %>
            <%= link_to author.name, aurelius_press_catalogue_author_path(author) %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
