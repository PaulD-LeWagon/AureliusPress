<%= render HeroComponent.new(
     title: "AureliusPress::Catalogue::Source#show",
     subtitle: "Find me in app/views/aurelius_press/catalogue/sources/show.html.erb",
     small: true,
   ) %>

<div class="container" template="AureliusPress::Catalogue::Source#show">

  <h1>Source <%= @source.title %></h1>

  <%= render partial: "aurelius_press/community/shared/engagement_bar", locals: { interactable: @source } %>

  <p><strong>Title:</strong> <%= @source.title %></p>
  
  <p><strong>Author:</strong> <%= @source.authors.map(&:name).join(", ") if @source.authors.any? %></p>

  <p><strong>Created At:</strong> <%= l(@source.created_at, format: :long) %></p>

  <p><strong>Updated At:</strong> <%= l(@source.updated_at, format: :long) %></p>

</div>
