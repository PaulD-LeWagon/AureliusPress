<%= render HeroComponent.new(title: "All Categories", subtitle: "Browse Categories", small: true) %>
<div class="container">
  <h1>Categories</h1>
  <ul>
    <% @categories.each do |category| %>
      <li><%= link_to category.name, aurelius_press_taxonomy_category_path(category) %></li>
    <% end %>
  </ul>
</div>
